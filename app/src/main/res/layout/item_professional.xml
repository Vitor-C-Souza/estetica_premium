<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvInitials"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_initials"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="AC" />

    <TextView
        android:id="@+id/tvProfessionalName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textColor="#2E3A59"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tvInitials"
        app:layout_constraintTop_toTopOf="@id/tvInitials"
        tools:text="Dra. Ana Costa" />

    <TextView
        android:id="@+id/tvSpecialty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvProfessionalName"
        app:layout_constraintTop_toBottomOf="@id/tvProfessionalName"
        tools:text="Dermatologista" />

    <ImageView
        android:id="@+id/ivStar"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="8dp"
        android:contentDescription="@string/icon_star"
        android:src="@drawable/ic_star"
        app:layout_constraintStart_toStartOf="@id/tvProfessionalName"
        app:layout_constraintTop_toBottomOf="@id/tvSpecialty"
        app:tint="@color/gold" />

    <TextView
        android:id="@+id/tvRating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textColor="@color/gray_text"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/ivStar"
        app:layout_constraintStart_toEndOf="@id/ivStar"
        app:layout_constraintTop_toTopOf="@id/ivStar"
        tools:text="5.0" />

</androidx.constraintlayout.widget.ConstraintLayout>