<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ol"
        android:textColor="#9E9E9E"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/nome_usuario"
        android:textColor="#2E3A59"
        android:textSize="28sp"
        android:textStyle="normal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

    <LinearLayout
        android:id="@+id/llButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tvUserName">

        <!-- Agendar Serviço -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cvSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivCalendar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_white"
                android:contentDescription="@string/icon_calendar"
                android:padding="12dp"
                android:src="@drawable/ic_calendar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvScheduleTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/agendar_servico"
                android:textColor="#2E3A59"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivCalendar"
                app:layout_constraintTop_toTopOf="@id/ivCalendar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/reserve_seu_horario"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@+id/tvScheduleTitle"
                app:layout_constraintTop_toBottomOf="@+id/tvScheduleTitle"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Meus Agendamentos -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cvMySchedules"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivClock"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_white"
                android:contentDescription="@string/icon_clock"
                android:padding="12dp"
                android:src="@drawable/ic_clock"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvMySchedulesTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/meus_agendamentos"
                android:textColor="#2E3A59"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivClock"
                app:layout_constraintTop_toTopOf="@id/ivClock" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ver_compromissos"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/tvMySchedulesTitle"
                app:layout_constraintTop_toBottomOf="@id/tvMySchedulesTitle"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Profissionais -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cvStaff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivPerson"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_white"
                android:contentDescription="@string/icon_person"
                android:padding="12dp"
                android:src="@drawable/ic_person"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvStaffTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/profissionais"
                android:textColor="#2E3A59"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivPerson"
                app:layout_constraintTop_toTopOf="@id/ivPerson" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/conheca_nossa_equipe"
                android:textColor="#9E9E9E"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="@id/tvStaffTitle"
                app:layout_constraintTop_toBottomOf="@id/tvStaffTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <!-- Featured Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_featured_card"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvFeaturedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/destaque"
            android:textColor="#E0E0E0"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/icon_sparkle"
            android:src="@drawable/ic_sparkle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvFeaturedTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tratamento_facial_premium"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="normal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFeaturedLabel" />

        <TextView
            android:id="@+id/tvFeaturedSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/experimente_nosso_servico_mais_procurado"
            android:textColor="#F5F5F5"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFeaturedTitle" />

        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button_white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/saiba_mais"
            android:textColor="#B8963C"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFeaturedSubtitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>